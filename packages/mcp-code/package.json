{
  "name": "payfin-mcp-code",
  "version": "0.1.0-beta.2",
  "description": "Read-only code access MCP server for PayFin repositories (npx-friendly, no Docker required)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "payfin-mcp-code": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "gitlab",
    "payfin"
  ],
  "author": "Sardorbek Bayakhmedov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://git.ipoint.uz/sbayakhmedov/payfin-mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@vscode/ripgrep": "^1.15.9",
    "node-cron": "^3.0.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
